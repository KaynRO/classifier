# Database
DB_PASSWORD=changeme_secure_password
DATABASE_URL=postgresql+asyncpg://classifier:${DB_PASSWORD}@postgres:5432/classifier
DATABASE_URL_SYNC=postgresql://classifier:${DB_PASSWORD}@postgres:5432/classifier

# Redis
REDIS_URL=redis://redis:6379/0

# JWT Auth
JWT_SECRET_KEY=changeme_jwt_secret_key_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Classifier credentials
TWOCAPTCHA_API_KEY=
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
URLHAUS_API_KEY=
GOOGLE_SAFEBROWSING_API_KEY=
TALOS_USERNAME=
TALOS_PASSWORD=
WATCHGUARD_USERNAME=
WATCHGUARD_PASSWORD=
PALOALTO_USERNAME=
PALOALTO_PASSWORD=
GMAIL_EMAIL=
GMAIL_APP_PASSWORD=

# Default admin user (created on first boot)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@classifier.local
ADMIN_PASSWORD=changeme_admin_password
